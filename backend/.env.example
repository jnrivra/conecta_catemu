# Puerto del servidor backend
PORT=3001

# Base de datos SQLite
DATABASE_PATH=../database/catemu.db

# Configuración de upload de archivos
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# n8n webhook (opcional)
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/report-created

# Claude API Key (opcional - para procesamiento con IA)
# CLAUDE_API_KEY=sk-ant-api03-xxxxx

# Configuración de CORS (producción)
# CORS_ORIGIN=https://catconecta.cl

# Configuración de email (opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@catconecta.cl
# SMTP_PASS=password

# Configuración de seguridad
# JWT_SECRET=cambiar-esta-clave-secreta-en-produccion
# SESSION_SECRET=otra-clave-secreta-para-sesiones