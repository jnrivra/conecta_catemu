# ============================================
# CATEMU CONECTA - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env y configura los valores

# --------------------------------------------
# BACKEND CONFIGURATION
# --------------------------------------------
# Puerto del servidor API
PORT=3001

# Entorno (development | production | test)
NODE_ENV=development

# Path a la base de datos SQLite
DATABASE_PATH=./database/catemu.db

# JWT Secret (generar uno aleatorio en producción)
JWT_SECRET=your-secret-key-here-change-in-production

# --------------------------------------------
# WHATSAPP BOT CONFIGURATION
# --------------------------------------------
# Nombre del bot (aparece en las respuestas)
BOT_NAME=CatemuConecta

# API Key de Anthropic (Claude) - Opcional
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Número de WhatsApp del bot (sin +)
BOT_PHONE_NUMBER=56920464349

# Modo del bot (production | development)
BOT_MODE=development

# --------------------------------------------
# FRONTEND CONFIGURATION
# --------------------------------------------
# URL de la API para el frontend
REACT_APP_API_URL=http://localhost:3001

# URL del WebSocket
REACT_APP_WS_URL=ws://localhost:3001

# Google Maps API Key (opcional, para mapas)
REACT_APP_GOOGLE_MAPS_KEY=

# --------------------------------------------
# N8N WORKFLOW AUTOMATION (Opcional)
# --------------------------------------------
# Desactivar cookies seguras para desarrollo local
N8N_SECURE_COOKIE=false

# Puerto de n8n
N8N_PORT=5678

# URL de n8n webhooks
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# --------------------------------------------
# EMAIL CONFIGURATION (Opcional)
# --------------------------------------------
# Servicio de email (gmail | outlook | smtp)
EMAIL_SERVICE=gmail

# Credenciales de email
EMAIL_USER=catemu.conecta@gmail.com
EMAIL_PASS=your-app-password

# Email para notificaciones
ADMIN_EMAIL=admin@municatemu.cl

# --------------------------------------------
# SMS CONFIGURATION (Opcional - Twilio)
# --------------------------------------------
# Twilio Account SID
TWILIO_ACCOUNT_SID=

# Twilio Auth Token
TWILIO_AUTH_TOKEN=

# Twilio Phone Number
TWILIO_PHONE_NUMBER=

# --------------------------------------------
# SECURITY CONFIGURATION
# --------------------------------------------
# Tasa límite de requests por minuto
RATE_LIMIT_MAX=100

# Ventana de tiempo para rate limit (ms)
RATE_LIMIT_WINDOW=60000

# Máximo tamaño de archivo upload (bytes)
MAX_FILE_SIZE=5242880

# Tipos de archivo permitidos
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# --------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------
# Para migración futura a PostgreSQL
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=catemu_conecta
# DB_USER=postgres
# DB_PASS=password

# --------------------------------------------
# MONITORING & ANALYTICS (Opcional)
# --------------------------------------------
# Sentry DSN para tracking de errores
SENTRY_DSN=

# Google Analytics ID
GA_TRACKING_ID=

# --------------------------------------------
# CLOUD STORAGE (Opcional)
# --------------------------------------------
# AWS S3 para almacenamiento de archivos
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=catemu-conecta-uploads

# --------------------------------------------
# MUNICIPIO CONFIGURATION
# --------------------------------------------
# Nombre del municipio
MUNICIPIO_NOMBRE=Catemu

# Código del municipio
MUNICIPIO_CODIGO=5702

# Coordenadas centrales del municipio
MUNICIPIO_LAT=-32.7805
MUNICIPIO_LNG=-70.9643

# Zona horaria
TZ=America/Santiago

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------
# Activar/desactivar características
ENABLE_WHATSAPP=true
ENABLE_GAMIFICATION=true
ENABLE_AI_CATEGORIZATION=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=true
ENABLE_EXPORT_EXCEL=true
ENABLE_EXPORT_PDF=true

# --------------------------------------------
# DEVELOPMENT TOOLS
# --------------------------------------------
# Activar logs detallados
DEBUG=false

# Puerto para debugging remoto
DEBUG_PORT=9229

# Mostrar queries SQL
LOG_SQL=false

# ============================================
# NOTAS IMPORTANTES:
# ============================================
# 1. NUNCA subas el archivo .env a Git
# 2. Mantén las API keys seguras
# 3. Usa valores diferentes en producción
# 4. Genera secrets aleatorios para JWT
# 5. Configura HTTPS en producción
# ============================================